# QuantPilot hybrid server deployment. Copy to /opt/quantpilot/.env.production.
NODE_ENV=production
QUANTPILOT_DEPLOYMENT=server
PORT=3000
WEB_PORT=3000

# Next.js basePath is compiled at build time. Re-run npm run build:server after changing it.
NEXT_PUBLIC_APP_URL=https://mantleofintelligence.com/smartstock
NEXT_PUBLIC_BASE_PATH=/smartstock
NEXT_PUBLIC_API_BASE=/smartstock

PROJECTS_DIR=/opt/quantpilot/data/projects
ENCRYPTION_KEY=replace-with-64-hex-characters

DATABASE_URL=postgresql://quantpilot:replace-with-database-password@127.0.0.1:5432/quantpilot?schema=public
TIMESCALEDB_IMAGE=timescale/timescaledb:2.27.1-pg18
POSTGRES_DB=quantpilot
POSTGRES_USER=quantpilot
POSTGRES_PASSWORD=replace-with-database-password
POSTGRES_PORT=5432

REDIS_URL=redis://127.0.0.1:6379/0
REDIS_IMAGE=redis:8-alpine
REDIS_PORT=6379
REDIS_NAMESPACE=quantpilot

QUANTPILOT_DEGRADATION_MODE=auto
QUANTPILOT_DATABASE_ENABLED=1
QUANTPILOT_DATABASE_REQUIRED=1
QUANTPILOT_MARKET_API_ENABLED=1
QUANTPILOT_MARKET_API_REQUIRED=0
QUANTPILOT_CLICKHOUSE_ENABLED=0
QUANTPILOT_CLICKHOUSE_REQUIRED=0
QUANTPILOT_OBSERVABILITY_ENABLED=0
QUANTPILOT_OBSERVABILITY_REQUIRED=0
QUANTPILOT_REDIS_REQUIRED=0

QUANTPILOT_MARKET_HOST=127.0.0.1
QUANTPILOT_MARKET_PORT=8000
QUANTPILOT_MARKET_API_URL=http://127.0.0.1:8000
QUANTPILOT_REDIS_CACHE_ENABLED=1
QUANTPILOT_SCREENER_CACHE_TTL_SECONDS=60
QUANTPILOT_SCREENER_PREFETCH_TIMEOUT_MS=45000

# Add the provider credentials that your installation actually uses.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_MS=30000

ANTHROPIC_BASE_URL=
ANTHROPIC_AUTH_TOKEN=
API_TIMEOUT_MS=3000000
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1

CODEX_MODEL=gpt-5.5
CODEX_MODEL_REASONING_EFFORT=low
CODEX_OPENAI_BASE_URL=
CODEX_OPENAI_API_KEY=
CODEX_MAX_TURNS=20
CODEX_MAX_THINKING_TOKENS=4096

PREVIEW_PORT_START=4100
PREVIEW_PORT_END=4999
QUANTPILOT_PREVIEW_PROXY_BASE=/smartstock/previews
QUANTPILOT_PREVIEW_PUBLIC_ORIGIN=https://mantleofintelligence.com
